{ "name": "vibe-music-app", "version": "1.0.0", "description": "A mood-based music streaming platform with Spotify & YouTube Music integration", "scripts": { "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"", "dev:frontend": "cd frontend && npm run dev", "dev:backend": "cd backend && npm run dev", "build": "npm run build:frontend && npm run build:backend", "build:frontend": "cd frontend && npm run build", "build:backend": "cd backend && npm run build", "start": "node backend/dist/server.js" }, "keywords": ["music", "mood", "streaming", "spotify", "youtube"], "author": "Docslayer93", "license": "MIT", "dependencies": {}, "devDependencies": { "concurrently": "^8.2.0" } }